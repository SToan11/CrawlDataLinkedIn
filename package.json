{
  "name": "linkedin-crawl-agent",
  "version": "1.0.0",
  "description": "API + worker system for LinkedIn crawl jobs with PostgreSQL",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev:api": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "prisma": "^6.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
