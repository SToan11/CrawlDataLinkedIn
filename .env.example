# App
NODE_ENV=development
API_PORT=3000
POSTGRES_PORT=5432
WORKER_POLL_MS=5000
WORKER_BATCH_SIZE=1

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/linkedin_crawl

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback
LINKEDIN_ACCESS_TOKEN=your_access_token

# Crawl Strategy: official_api or playwright_scrape
CRAWL_STRATEGY=playwright_scrape

# Playwright fallback settings
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your_password
LINKEDIN_COOKIE_LI_AT=
PROXY_URL=
PLAYWRIGHT_HEADLESS=true
MIN_DELAY_MS=1200
MAX_DELAY_MS=3500
